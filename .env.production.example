# ==================================
# DOMAIN
# ==================================
DOMAIN=seudominio.com

# ==================================
# DATABASE (PostgreSQL já existente)
# ==================================
# Use o PostgreSQL que já está rodando na sua VM
DATABASE_URL="postgresql://climb_user:SENHA_FORTE@postgres_postgres.1.gzernj9xohue6vrskci5pw7ii:5432/climb_delivery?schema=public"

# ==================================
# JWT
# ==================================
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="sua_chave_secreta_forte_aqui"
JWT_EXPIRATION="7d"

# ==================================
# CORS
# ==================================
CORS_ORIGIN="https://seudominio.com,https://www.seudominio.com"

# ==================================
# EMAIL (SMTP)
# ==================================
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER="seu-email@gmail.com"
MAIL_PASSWORD="sua-senha-app"
MAIL_FROM="Climb Delivery <seu-email@gmail.com>"

# ==================================
# FRONTEND
# ==================================
FRONTEND_URL="https://seudominio.com"

# ==================================
# UPLOAD
# ==================================
# 10MB em bytes
MAX_FILE_SIZE=10485760
